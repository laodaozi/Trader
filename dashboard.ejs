<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title><%= title %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      background: linear-gradient(180deg, #fef9ef 0%, #fdf5e6 30%, #fefcf8 100%);
      color: #3d3a35;
      min-height: 100vh;
      max-width: 480px;
      margin: 0 auto;
      -webkit-font-smoothing: antialiased;
    }
    .app-header {
      padding: 24px 20px 16px;
      display: flex; align-items: center; justify-content: space-between;
      background: linear-gradient(135deg, #fff8e7, #fffbef);
      border-bottom: 1px solid rgba(184,134,11,0.08);
    }
    .app-title { font-size: 22px; font-weight: 700; color: #5a4a2a; letter-spacing: 0.5px; }
    .app-version { font-size: 11px; color: #b8a06a; background: rgba(184,134,11,0.08); padding: 3px 10px; border-radius: 10px; }
    .m-tabs {
      display: flex; gap: 0;
      padding: 0 12px;
      background: #fffbef;
      border-bottom: 1px solid rgba(184,134,11,0.08);
      position: sticky; top: 0; z-index: 10;
    }
    .m-tab {
      flex: 1; text-align: center;
      padding: 12px 4px 10px;
      font-size: 13px; font-weight: 600; color: #b8a06a;
      cursor: pointer; border-bottom: 2px solid transparent;
      transition: all 0.2s; user-select: none;
    }
    .m-tab.active { color: #8b6914; border-bottom-color: #d4a843; }
    .m-content { padding: 16px; }
    .m-panel { display: none; }
    .m-panel.active { display: block; }
    .card {
      background: #fffdf7;
      border: 1px solid rgba(184,134,11,0.10);
      border-radius: 14px;
      padding: 16px;
      margin-bottom: 12px;
      box-shadow: 0 1px 3px rgba(184,134,11,0.04);
    }
    .card-title {
      font-size: 13px; font-weight: 700; color: #8b6914; text-transform: uppercase;
      letter-spacing: 1px; margin-bottom: 10px;
    }
    .thermo-phase { font-size: 32px; font-weight: 700; text-align: center; }
    .thermo-phase.bull { color: #b45309; }
    .thermo-phase.bear { color: #991b1b; }
    .thermo-phase.neutral { color: #8b6914; }
    .thermo-detail { font-size: 13px; color: #9a8c6e; text-align: center; margin-top: 4px; }
    .thermo-bar { height: 6px; background: rgba(184,134,11,0.06); border-radius: 3px; margin: 12px 0 0; overflow: hidden; }
    .thermo-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, #16a34a, #ca8a04, #dc2626); }
    .account-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
    .acc-cell { text-align: center; padding: 10px 6px; background: rgba(184,134,11,0.03); border-radius: 10px; }
    .acc-label { font-size: 10px; color: #b8a06a; text-transform: uppercase; letter-spacing: 0.5px; }
    .acc-value { font-size: 16px; font-weight: 700; color: #5a4a2a; margin-top: 2px; }
    .acc-state.good { color: #16a34a; }
    .acc-state.bad { color: #dc2626; }
    .signal-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr 1fr; gap: 6px; }
    .sig-cell { text-align: center; padding: 10px 4px; background: rgba(184,134,11,0.03); border-radius: 8px; }
    .sig-icon { font-size: 20px; }
    .sig-count { font-size: 18px; font-weight: 700; margin-top: 2px; }
    .sig-label { font-size: 10px; color: #b8a06a; margin-top: 1px; }
    .stock-item {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 0;
      border-bottom: 1px solid rgba(184,134,11,0.06);
    }
    .stock-item:last-child { border-bottom: none; }
    .s-rank { width: 22px; text-align: center; font-size: 11px; color: #b8a06a; }
    .s-body { flex: 1; min-width: 0; }
    .s-code { font-size: 10px; color: #b8a06a; font-family: monospace; }
    .s-name { font-size: 14px; font-weight: 600; }
    .s-tag { font-size: 11px; color: #9a8c6e; }
    .s-score { font-size: 22px; font-weight: 700; min-width: 44px; text-align: right; }
    .diag-table { width: 100%; font-size: 11px; border-collapse: collapse; margin-top: 8px; }
    .diag-table th { color: #b8a06a; font-weight: 600; text-align: left; padding: 6px 4px; border-bottom: 2px solid rgba(184,134,11,0.12); font-size: 10px; }
    .diag-table td { padding: 6px 4px; border-bottom: 1px solid rgba(184,134,11,0.04); }
    .trk-table { width: 100%; font-size: 11px; border-collapse: collapse; margin-top: 8px; }
    .trk-table th { color: #b8a06a; font-weight: 600; text-align: left; padding: 6px 4px; border-bottom: 2px solid rgba(184,134,11,0.12); font-size: 10px; }
    .trk-table td { padding: 6px 4px; border-bottom: 1px solid rgba(184,134,11,0.04); }
    .trk-table .code-cell { font-family: monospace; font-size: 10px; color: #b8a06a; cursor: pointer; }
    .verdict { font-size: 10px; font-weight: 600; padding: 2px 6px; border-radius: 4px; display: inline-block; }
    .v-hit { background: rgba(22,163,74,0.1); color: #16a34a; }
    .v-miss { background: rgba(220,38,38,0.08); color: #dc2626; }
    .v-pend { background: rgba(59,130,246,0.08); color: #2563eb; }
    .v-nodata { background: rgba(0,0,0,0.04); color: #9a8c6e; }
    .v-neutral { background: rgba(212,168,67,0.08); color: #d4a843; }
    .hit-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 12px; }
    .hit-cell { text-align: center; padding: 10px 6px; background: rgba(184,134,11,0.03); border-radius: 8px; }
    .hit-h { font-size: 10px; color: #b8a06a; }
    .hit-v { font-size: 20px; font-weight: 700; }
    .bt-card { padding: 14px; background: rgba(184,134,11,0.03); border-radius: 10px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
    .bt-card:hover { background: rgba(184,134,11,0.06); }
    .bt-name { font-weight: 600; font-size: 13px; }
    .bt-date { font-size: 10px; color: #b8a06a; }
    .bt-link { font-size: 11px; color: #8b6914; font-weight: 600; }
    .filter-row { display: flex; gap: 6px; margin-bottom: 10px; overflow-x: auto; }
    .filter-btn { padding: 4px 10px; font-size: 11px; border: 1px solid rgba(184,134,11,0.15); border-radius: 6px; background: #fffdf7; color: #8b6914; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
    .filter-btn.on { background: #d4a843; color: #fff; border-color: #d4a843; }
    .loading { text-align: center; padding: 40px 0; }
    .spin { display: inline-block; width: 24px; height: 24px; border: 2px solid rgba(184,134,11,0.15); border-top-color: #d4a843; border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .nodata { text-align: center; padding: 40px 0; color: #b8a06a; font-size: 13px; }
    /* V5.3: 好运哥交易纪律卡片 */
    .haoyunge-card { background: linear-gradient(135deg, #fffbeb 0%, #fefce8 100%); }
    .haoyunge-posture { font-size: 22px; font-weight: 800; text-align: center; padding: 6px 0; letter-spacing: 2px; }
    .haoyunge-meta { display: flex; justify-content: center; gap: 6px; font-size: 11px; color: #9a8c6e; margin-bottom: 10px; flex-wrap: wrap; }
    .haoyunge-meta-sep { color: #d4c493; }
    .haoyunge-rules { display: flex; flex-direction: column; gap: 4px; }
    .haoyunge-rule { font-size: 11px; color: #5a4a2a; padding: 6px 10px; background: rgba(184,134,11,0.04); border-radius: 6px; border-left: 3px solid #d4a843; line-height: 1.5; }
    .refresh-bar { text-align: center; padding: 12px 0 24px; font-size: 11px; color: #caba8a; border-top: 1px solid rgba(184,134,11,0.06); margin-top: 20px; }
    .refresh-bar span { cursor: pointer; color: #8b6914; font-weight: 600; }
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(245,235,210,0.85); z-index: 100; overflow-y: auto; max-width: 480px; margin: 0 auto; }
    .modal-overlay.show { display: block; }
    .modal-card { background: #fffdf7; margin: 20px 12px; border-radius: 14px; padding: 16px; border: 1px solid rgba(184,134,11,0.12); }
    .modal-close { float: right; font-size: 20px; cursor: pointer; padding: 0 8px; color: #b8a06a; }

    /* ── Cycleradar 暗色区域 ── */
    #p-cycleradar { background: #0f172a; margin: -16px; padding: 16px; min-height: 60vh; }
    .cr-cards { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; margin-bottom: 16px; }
    .cr-card { background: #1e293b; border: 1px solid #273548; border-radius: 10px; padding: 12px 8px; text-align: center; }
    .cr-val { display: block; font-size: 22px; font-weight: 800; }
    .cr-lbl { display: block; font-size: 10px; color: #94a3b8; margin-top: 3px; }
    .cr-active .cr-val { color: #3b82f6; }
    .cr-ratio .cr-val { color: #22c55e; }
    .cr-section { background: #1e293b; border: 1px solid #273548; border-radius: 12px; padding: 14px; margin-bottom: 12px; }
    .cr-section-title { font-size: 13px; font-weight: 700; color: #e2e8f0; margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
    .cr-dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
    .cr-dot-long { background: #22c55e; }
    .cr-dot-short { background: #ef4444; }
    .cr-sig-card { display: flex; align-items: center; gap: 10px; background: #273548; border-radius: 8px; padding: 10px 12px; margin-bottom: 7px; border-left: 3px solid transparent; }
    .cr-sig-long { border-left-color: #22c55e; }
    .cr-sig-short { border-left-color: #ef4444; }
    .cr-dir { font-size: 11px; font-weight: 800; padding: 3px 8px; border-radius: 5px; min-width: 32px; text-align: center; flex-shrink: 0; }
    .cr-dir-long { background: #052e16; color: #22c55e; }
    .cr-dir-short { background: #450a0a; color: #ef4444; }
    .cr-sig-asset { font-size: 13px; font-weight: 700; color: #e2e8f0; min-width: 80px; flex-shrink: 0; }
    .cr-sig-code { font-size: 10px; color: #94a3b8; font-weight: 400; margin-left: 4px; }
    .cr-sig-meta { font-size: 11px; color: #94a3b8; flex: 1; min-width: 0; }
    .cr-sig-strat { color: #3b82f6; font-weight: 600; }
    .cr-tags { margin-top: 3px; }
    .cr-tag { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 10px; font-weight: 600; margin-right: 3px; }
    .cr-tag-reason { background: #1e3a5f; color: #60a5fa; }
    .cr-sig-actionable {
      display: block;
      font-size: 11px;
      color: #cbd5e1;
      background: rgba(59,130,246,0.06);
      border-left: 2px solid #3b82f6;
      padding: 3px 8px;
      margin-bottom: 4px;
      border-radius: 0 4px 4px 0;
      line-height: 1.5;
    }
    .cr-tag-tier { background: #052e16; color: #22c55e; }
    .cr-conf { display: flex; flex-direction: column; align-items: flex-end; gap: 3px; min-width: 52px; flex-shrink: 0; }
    .cr-conf-val { font-size: 16px; font-weight: 800; }
    .cr-conf-bar { width: 48px; height: 4px; border-radius: 2px; background: #0f172a; overflow: hidden; }
    .cr-conf-fill { height: 100%; border-radius: 2px; }
    .cr-conf-high { background: #22c55e; }
    .cr-conf-med { background: #f59e0b; }
    .cr-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .cr-strat-row { display: flex; align-items: center; gap: 8px; padding: 8px 0; border-bottom: 1px solid #273548; }
    .cr-strat-row:last-child { border-bottom: none; }
    .cr-strat-name { font-size: 11px; font-weight: 700; color: #e2e8f0; flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cr-strat-count { font-size: 11px; color: #3b82f6; font-weight: 700; flex-shrink: 0; }
    .cr-strat-ratio { font-size: 10px; color: #94a3b8; flex-shrink: 0; }
    .cr-heat-table { width: 100%; border-collapse: collapse; }
    .cr-heat-table th { text-align: left; padding: 6px 8px; border-bottom: 2px solid #273548; color: #94a3b8; font-size: 10px; font-weight: 600; }
    .cr-heat-table td { padding: 8px; border-bottom: 1px solid #273548; font-weight: 700; text-align: center; font-size: 13px; }
    .cr-heat-label { text-align: left !important; font-size: 11px; color: #e2e8f0; }
    .cr-heat-hot { background: #052e16; color: #22c55e; }
    .cr-heat-warm { background: #422006; color: #f59e0b; }
     .cr-heat-cold { background: #1e293b; color: #94a3b8; }
      /* ── V3.9.4 四分类卡片 ── */
      .cr-ico { font-size: 15px; }
      .cr-event-card { display: flex; flex-direction: column; gap: 6px; padding: 10px 0; border-bottom: 1px solid #273548; }
      .cr-event-card:last-child { border-bottom: none; }
       .cr-event-row { display: flex; gap: 10px; align-items: flex-start; }
        .cr-event-pic { width: 42px; height: 42px; border-radius: 6px; object-fit: cover; flex-shrink: 0; background: #1e293b; }
        .cr-event-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
       .cr-event-title { font-size: 13px; color: #f1f5f9; font-weight: 600; line-height: 1.4; }
       .cr-event-thesis { font-size: 11px; color: #94a3b8; line-height: 1.4; margin-top: 2px; }
       .cr-event-source { font-size: 10px; color: #64748b; }
       .cr-event-tickers { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 2px; }
        .cr-ticker-tag { font-size: 10px; background: rgba(59,130,246,0.12); color: #60a5fa; padding: 2px 6px; border-radius: 4px; white-space: nowrap; }

      /* ── V4.3 热点事件紧凑格式 ── */
      .cr-hot-card { padding: 12px 0; border-bottom: 1px solid #273548; }
      .cr-hot-card:last-child { border-bottom: none; }
      .cr-hot-label { font-size: 10px; font-weight: 700; color: #f59e0b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
      .cr-hot-summary { font-size: 13px; color: #f1f5f9; font-weight: 600; line-height: 1.5; margin-bottom: 4px; }
      .cr-hot-source { font-size: 10px; color: #64748b; margin-bottom: 6px; }
      .cr-event-tickers-v43 { display: flex; flex-direction: column; gap: 3px; margin-top: 4px; }
      .cr-ticker-item { font-size: 11px; color: #cbd5e1; padding: 3px 6px; background: rgba(34,197,94,0.08); border-radius: 4px; display: inline-block; }
      .cr-ticker-reason { font-size: 10px; color: #94a3b8; }

      /* ── V4.1 信号卡片可展开 ── */
      .cr-sig-expandable { cursor: pointer; transition: background 0.15s; position: relative; }
      .cr-sig-expandable:hover { background: #334155; }
      .cr-sig-expandable::after {
        content: '▾'; font-size: 10px; color: #64748b; 
        position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
        transition: transform 0.2s;
      }
      .cr-sig-expanded .cr-sig-meta { overflow: visible; white-space: normal; }
      .cr-sig-expandable.cr-sig-expanded::after { transform: translateY(-50%) rotate(180deg); }
      .cr-sig-detail { display: none; }
      .cr-sig-expanded .cr-sig-detail { display: block; margin-top: 10px; padding-top: 10px; border-top: 1px solid #334155; }
      .cr-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
      .cr-detail-cell { padding: 6px 8px; background: #0f172a; border-radius: 6px; }
      .cr-detail-lbl { font-size: 9px; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
      .cr-detail-val { font-size: 12px; color: #e2e8f0; font-weight: 700; margin-top: 2px; }
      .cr-detail-expiry-ok { color: #22c55e; }
      .cr-detail-expiry-warn { color: #f59e0b; }
      .cr-detail-expiry-expired { color: #ef4444; }
      .cr-all-tags { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 4px; }
      /* ── V4.3 多空选择标准展开 ── */
      .cr-dir-reason { margin-top: 10px; padding: 10px; background: rgba(34,197,94,0.06); border-radius: 8px; border-left: 3px solid rgba(34,197,94,0.3); }
      .cr-dir-reason-label { font-size: 11px; font-weight: 700; color: #e2e8f0; margin-bottom: 6px; }
      .cr-dir-reason-item { font-size: 11px; color: #cbd5e1; line-height: 1.6; padding: 2px 0; }
      /* ── V4.3 Alpha 推荐 badge ── */
      .cr-rec-badge { display: inline-block; margin-left: 8px; padding: 2px 8px; border-radius: 10px; background: linear-gradient(135deg, #f59e0b, #ef4444); color: #fff; font-size: 10px; font-weight: 700; letter-spacing: 0.5px; vertical-align: middle; }
      /* ── V4.1 市场摘要卡片 ── */
      .cr-summary-card { background: linear-gradient(135deg, #1e3a5f 0%, #1a2a4a 100%); border: 1px solid #2d4a6f; border-radius: 12px; padding: 16px; margin-bottom: 16px; }
      .cr-summary-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
      .cr-summary-regime { font-size: 20px; font-weight: 800; letter-spacing: 1px; }
      .cr-summary-regime.offense { color: #22c55e; }
      .cr-summary-regime.defense { color: #ef4444; }
      .cr-summary-regime.balance { color: #f59e0b; }
      .cr-summary-action { font-size: 11px; padding: 3px 10px; border-radius: 12px; font-weight: 600; }
      .cr-summary-action.offense { background: #052e16; color: #22c55e; }
      .cr-summary-action.defense { background: #450a0a; color: #ef4444; }
      .cr-summary-action.balance { background: #422006; color: #f59e0b; }
      .cr-summary-conf { font-size: 12px; font-weight: 700; color: #f59e0b; margin-left: 6px; }
      .cr-summary-stats { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; }
      .cr-summary-stat { text-align: center; }
      .cr-summary-stat-val { font-size: 18px; font-weight: 800; color: #e2e8f0; }
      .cr-summary-stat-lbl { font-size: 9px; color: #64748b; margin-top: 2px; }
      .cr-summary-thesis { margin-top: 10px; padding-top: 10px; border-top: 1px solid #2d4a6f; font-size: 11px; color: #94a3b8; line-height: 1.5; }

      /* V4.2 RSS 时效条 */
      .cr-freshness { display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: #1e293b; border-left: 3px solid #64748b; border-radius: 6px; margin-bottom: 12px; font-size: 12px; }
      .cr-freshness-icon { font-size: 13px; flex-shrink: 0; }
      .cr-freshness-label { color: #e2e8f0; font-weight: 600; }
      .cr-freshness-time { color: #64748b; font-size: 10px; margin-left: auto; }

      /* ── V5.1 信号Tab顶部统计栏 ── */
      .cr-stats-bar { display: flex; justify-content: center; align-items: center; gap: 6px; padding: 10px 12px; margin-bottom: 12px; background: linear-gradient(135deg, #1a2a4a 0%, #1e3a5f 100%); border: 1px solid #2d4a6f; border-radius: 10px; flex-wrap: wrap; }
      .cr-stat-item { display: flex; flex-direction: column; align-items: center; min-width: 52px; }
      .cr-stat-val { font-size: 18px; font-weight: 800; color: #e2e8f0; line-height: 1.2; }
      .cr-stat-label { font-size: 9px; color: #64748b; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.3px; }
      .cr-stat-sep { color: #334155; font-size: 14px; margin: 0 4px; }

      /* ── V5.1 风险警告 ── */
      .cr-risk-warnings { margin-top: 10px; display: flex; flex-direction: column; gap: 5px; }
      .cr-risk-item { font-size: 11px; color: #f59e0b; line-height: 1.5; padding: 4px 10px; background: rgba(245, 158, 11, 0.08); border-left: 3px solid #f59e0b; border-radius: 0 6px 6px 0; }

      /* ── V5.0 事件叙事解读区块 ── */
      .cr-en-block { margin-bottom: 14px; }
      .cr-en-header { background: linear-gradient(135deg, #1e3a5f 0%, #1a2a4a 100%); border: 1px solid #2d4a6f; border-radius: 12px; padding: 14px 16px; margin-bottom: 10px; }
      .cr-en-header .cr-summary-regime { font-size: 16px; }
      .cr-en-thesis { margin-top: 8px; font-size: 12px; color: #cbd5e1; line-height: 1.6; }
      .cr-en-fresh { margin-top: 6px; font-size: 10px; color: #475569; }
      .cr-en-events { }
      /* ── V5.2 事件解读卡片（1:1 复刻 /opt/cycleradar/dashboard.py CSS）── */
      .ev-card { background:#1e2a4a; border-radius:8px; padding:10px 12px; margin:8px 0; border-left:3px solid #4fc3f7; }
      .ev-header { display:flex; align-items:center; gap:7px; flex-wrap:wrap; margin-bottom:5px; }
      .ev-rank { font-size:11px; font-weight:700; color:#4fc3f7; background:#0d2040; padding:2px 6px; border-radius:3px; flex-shrink:0; }
      .ev-title { font-size:13px; font-weight:700; color:#fff; flex:1; min-width:0; }
      .ev-decay { font-size:10px; color:#888; background:#2a2a3a; padding:1px 5px; border-radius:3px; flex-shrink:0; }
      .ev-interp { font-size:12px; color:#ccc; line-height:1.55; margin-bottom:6px; }
      .ev-tags { display:flex; flex-wrap:wrap; gap:5px; margin-bottom:5px; }
      .ev-tag { font-size:10px; padding:2px 7px; border-radius:3px; font-weight:600; }
      .ev-tag.bull   { background:#1b2e1b; color:#ff6b6b; }
      .ev-tag.bear   { background:#1b1b2e; color:#6bff6b; }
      .ev-tag.neutral{ background:#2a2a3a; color:#aaa; }
      .ev-source { font-size:10px; color:#666; }
      .ev-stocks { display:flex; flex-wrap:wrap; gap:5px; margin:5px 0 4px; }
      .ev-stock { font-size:11px; color:#e0e0e0; background:#1a2540; padding:2px 7px; border-radius:4px; border:1px solid #2a3a5a; cursor:pointer; user-select:none; }
      .ev-stock small { color:#888; font-size:10px; margin-left:2px; }
      .ev-stock:hover { background:#2a3a60; border-color:#4fc3f7; }
      .ev-stock.expanded { background:#2a3a60; border-color:#4fc3f7; }
      .ev-stock-more { font-size:10px; color:#4fc3f7; padding:2px 6px; align-self:center; }
      .ev-stock-reason { display:none; font-size:10px; color:#9ab; margin-top:3px; padding:3px 6px; background:rgba(79,195,247,0.08); border-left:2px solid #4fc3f7; border-radius:0 3px 3px 0; box-sizing:border-box; }
  </style>
</head>
<body>
<div class="app-header">
  <span class="app-title">☀️ <%= title %></span>
  <span class="app-version"><%= appVersion || 'V5.2' %></span>
</div>
<div class="m-tabs">
  <div class="m-tab active" data-tab="overview">📊 概览</div>
  <div class="m-tab" data-tab="watchlist">📱 自选</div>
  <div class="m-tab" data-tab="cycleradar">📡 信号</div>
</div>
<div class="m-content">
  <div class="m-panel active" id="p-overview">
    <div id="overview-loading" class="loading"><div class="spin"></div></div>
    <div id="overview-content" style="display:none"></div>
  </div>
  <div class="m-panel" id="p-watchlist">
    <div id="wl-loading" class="loading"><div class="spin"></div></div>
    <div id="wl-content" style="display:none"></div>
  </div>
  <div class="m-panel" id="p-cycleradar">
    <div id="cr-loading" class="loading"><div class="spin"></div></div>
    <div id="cr-content" style="display:none"></div>
  </div>
</div>
<div class="refresh-bar">数据更新 <span onclick="refreshAll()">🔄 刷新</span></div>
<div class="modal-overlay" id="stock-modal" onclick="closeModal()">
  <div class="modal-card" onclick="event.stopPropagation()">
    <span class="modal-close" onclick="closeModal()">✕</span>
    <div id="modal-content"></div>
  </div>
</div>
<script src="/mobile-assets/app.js?v=<%= appVersion %>"></script>
</body>
</html>
