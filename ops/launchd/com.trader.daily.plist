<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.trader.daily</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__PROJECT_DIR__/ops/orchestrator.sh</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>    <integer>8</integer>
    <key>Minute</key>  <integer>45</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__PROJECT_DIR__/output/logs/launchd_stdout.log</string>
  <key>StandardErrorPath</key>
  <string>__PROJECT_DIR__/output/logs/launchd_stderr.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>/Users/scott</string>
  </dict>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
