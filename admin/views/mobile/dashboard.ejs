<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title><%= title %></title>
  <style>
    :root {
      --m-bg: #0a0e1a;
      --m-surface: #111827;
      --m-surface-2: #1e293b;
      --m-border: #1e293b;
      --m-primary: #3b82f6;
      --m-positive: #10b981;
      --m-negative: #ef4444;
      --m-warn: #f59e0b;
      --m-text: #e2e8f0;
      --m-text-2: #94a3b8;
      --m-text-3: #64748b;
      --m-etf: #a78bfa;
      --m-primary-rgb: 59,130,246;
      --m-positive-rgb: 16,185,129;
      --m-negative-rgb: 239,68,68;
      --m-warn-rgb: 245,158,11;
      --m-mono: "JetBrains Mono", "SF Mono", Menlo, monospace;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
      background: var(--m-bg);
      color: var(--m-text);
      min-height: 100vh;
      max-width: 480px;
      margin: 0 auto;
      -webkit-font-smoothing: antialiased;
    }
    .app-header {
      padding: 24px 20px 16px;
      display: flex; align-items: center; justify-content: space-between;
      background: var(--m-surface);
      border-bottom: 1px solid var(--m-border);
    }
    .app-title { font-size: 22px; font-weight: 700; color: var(--m-text); letter-spacing: 0.5px; }
    .app-version { font-size: 11px; color: var(--m-text-2); background: rgba(var(--m-primary-rgb), 0.12); padding: 3px 10px; border-radius: 10px; }
    .m-tabs {
      display: flex; gap: 0;
      padding: 0 12px;
      background: var(--m-surface-2);
      border-bottom: 1px solid var(--m-border);
      position: sticky; top: 0; z-index: 10;
    }
    .m-tab {
      flex: 1; text-align: center;
      padding: 12px 4px 10px;
      font-size: 13px; font-weight: 600; color: var(--m-text-2);
      cursor: pointer; border-bottom: 2px solid transparent;
      transition: all 0.2s; user-select: none;
    }
    .m-tab.active { color: var(--m-primary); border-bottom-color: var(--m-primary); }
    .m-content { padding: 16px; }
    .m-panel { display: none; }
    .m-panel.active { display: block; }
    .card {
      background: var(--m-surface);
      border: 1px solid var(--m-border);
      border-radius: 10px;
      padding: 16px;
      margin-bottom: 12px;
    }
    .card-title {
      font-size: 13px; font-weight: 700; color: var(--m-primary); text-transform: uppercase;
      letter-spacing: 1px; margin-bottom: 10px;
    }
    .thermo-phase { font-size: 32px; font-weight: 700; text-align: center; }
    .thermo-phase.bull { color: var(--m-positive); }
    .thermo-phase.bear { color: var(--m-negative); }
    .thermo-phase.neutral { color: var(--m-warn); }
    .thermo-detail { font-size: 13px; color: var(--m-text-2); text-align: center; margin-top: 4px; }
    .thermo-bar { height: 6px; background: var(--m-surface-2); border-radius: 3px; margin: 12px 0 0; overflow: hidden; }
    .thermo-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--m-positive), var(--m-warn), var(--m-negative)); }
    .account-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; }
    .acc-cell { text-align: center; padding: 10px 6px; background: var(--m-surface-2); border-radius: 10px; }
    .acc-label { font-size: 10px; color: var(--m-text-3); text-transform: uppercase; letter-spacing: 0.5px; }
    .acc-value { font-size: 16px; font-weight: 700; color: var(--m-text); margin-top: 2px; }
    .acc-state.good { color: var(--m-positive); }
    .acc-state.bad { color: var(--m-negative); }
    .signal-row { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr 1fr; gap: 6px; }
    .sig-cell { text-align: center; padding: 10px 4px; background: var(--m-surface-2); border-radius: 8px; }
    .sig-icon { font-size: 20px; }
    .sig-count { font-size: 18px; font-weight: 700; margin-top: 2px; }
    .sig-label { font-size: 10px; color: var(--m-text-2); margin-top: 1px; }
    .stock-item {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 0;
      border-bottom: 1px solid var(--m-border);
    }
    .stock-item:last-child { border-bottom: none; }
    .wl-row { display: flex; align-items: center; gap: 10px; padding: 12px 10px; border-bottom: 1px solid var(--m-border); cursor: pointer; transition: background 0.12s; -webkit-tap-highlight-color: transparent; }
    .wl-row:last-child { border-bottom: none; }
    .wl-row:active { background: rgba(var(--m-primary-rgb), 0.08); }
    .wl-left { flex: 1; min-width: 0; }
    .wl-name { font-size: 13px; font-weight: 600; color: var(--m-text); display: block; }
    .wl-code { font-size: 10px; color: var(--m-text-3); font-family: var(--m-mono); margin-left: 6px; }
    .wl-zone { display: flex; gap: 12px; margin-top: 4px; }
    .wl-zone-item { display: flex; flex-direction: column; }
    .wl-zone-label { font-size: 9px; color: var(--m-text-3); text-transform: uppercase; }
    .wl-zone-val { font-size: 12px; font-weight: 600; color: var(--m-text); }
    .wl-right { display: flex; flex-direction: column; align-items: flex-end; gap: 3px; min-width: 0; }
    .s-rank { width: 22px; text-align: center; font-size: 11px; color: var(--m-text-3); }
    .s-body { flex: 1; min-width: 0; }
    .s-code { font-size: 10px; color: var(--m-text-3); font-family: monospace; }
    .s-name { font-size: 14px; font-weight: 600; }
    .s-tag { font-size: 11px; color: var(--m-text-2); }
    .s-score { font-size: 22px; font-weight: 700; min-width: 44px; text-align: right; }
    .diag-table { width: 100%; font-size: 11px; border-collapse: collapse; margin-top: 8px; }
    .diag-table th { color: var(--m-text-3); font-weight: 600; text-align: left; padding: 6px 4px; border-bottom: 2px solid var(--m-border); font-size: 10px; }
    .diag-table td { padding: 6px 4px; border-bottom: 1px solid var(--m-border); }
    .trk-table { width: 100%; font-size: 11px; border-collapse: collapse; margin-top: 8px; }
    .trk-table th { color: var(--m-text-3); font-weight: 600; text-align: left; padding: 6px 4px; border-bottom: 2px solid var(--m-border); font-size: 10px; }
    .trk-table td { padding: 6px 4px; border-bottom: 1px solid var(--m-border); }
    .trk-table .code-cell { font-family: monospace; font-size: 10px; color: var(--m-text-3); cursor: pointer; }
    .verdict { font-size: 10px; font-weight: 600; padding: 2px 6px; border-radius: 4px; display: inline-block; }
    .v-hit { background: rgba(var(--m-positive-rgb), 0.12); color: var(--m-positive); }
    .v-miss { background: rgba(var(--m-negative-rgb), 0.1); color: var(--m-negative); }
    .v-pend { background: rgba(var(--m-primary-rgb), 0.1); color: var(--m-primary); }
    .v-nodata { background: rgba(255,255,255,0.04); color: var(--m-text-2); }
    .v-neutral { background: rgba(var(--m-warn-rgb), 0.08); color: var(--m-warn); }
    .hit-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-bottom: 12px; }
    .hit-cell { text-align: center; padding: 10px 6px; background: var(--m-surface-2); border-radius: 8px; }
    .hit-h { font-size: 10px; color: var(--m-text-3); }
    .hit-v { font-size: 20px; font-weight: 700; }
    .bt-card { padding: 14px; background: var(--m-surface-2); border-radius: 10px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center; cursor: pointer; }
    .bt-card:hover { background: rgba(var(--m-primary-rgb), 0.08); }
    .bt-name { font-weight: 600; font-size: 13px; }
    .bt-date { font-size: 10px; color: var(--m-text-2); }
    .bt-link { font-size: 11px; color: var(--m-primary); font-weight: 600; }
    .filter-row { display: flex; gap: 6px; margin-bottom: 10px; overflow-x: auto; }
    .filter-btn { padding: 4px 10px; font-size: 11px; border: 1px solid var(--m-border); border-radius: 6px; background: var(--m-surface); color: var(--m-primary); cursor: pointer; white-space: nowrap; flex-shrink: 0; }
    .filter-btn.on { background: var(--m-primary); color: #fff; border-color: var(--m-primary); }
    .loading { text-align: center; padding: 40px 0; }
    .spin { display: inline-block; width: 24px; height: 24px; border: 2px solid var(--m-border); border-top-color: var(--m-primary); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .nodata { text-align: center; padding: 40px 0; color: var(--m-text-2); font-size: 13px; }
    .haoyunge-card { background: var(--m-surface); }
    .haoyunge-posture { font-size: 22px; font-weight: 800; text-align: center; padding: 6px 0; letter-spacing: 2px; }
    .haoyunge-meta { display: flex; justify-content: center; gap: 6px; font-size: 11px; color: var(--m-text-2); margin-bottom: 10px; flex-wrap: wrap; }
    .haoyunge-meta-sep { color: var(--m-text-3); }
    .haoyunge-rules { display: flex; flex-direction: column; gap: 4px; }
    .haoyunge-rule { font-size: 11px; color: var(--m-text); padding: 6px 10px; background: var(--m-surface-2); border-radius: 6px; border-left: 3px solid var(--m-warn); line-height: 1.5; }
    .refresh-bar { text-align: center; padding: 12px 0 24px; font-size: 11px; color: var(--m-text-3); border-top: 1px solid var(--m-border); margin-top: 20px; }
    .refresh-bar span { cursor: pointer; color: var(--m-primary); font-weight: 600; }
    .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(10,14,26,0.85); z-index: 100; overflow-y: auto; max-width: 480px; margin: 0 auto; }
    .modal-overlay.show { display: block; }
    .modal-card { background: var(--m-surface); margin: 20px 12px; border-radius: 10px; padding: 16px; border: 1px solid var(--m-border); }
    .modal-close { float: right; font-size: 20px; cursor: pointer; padding: 0 8px; color: var(--m-text-2); }
    /* ── Cycleradar 终端风格面板 ── */
    #p-cycleradar { background: var(--m-bg); margin: -16px; padding: 16px; min-height: 60vh; }
    .cr-cards { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; margin-bottom: 16px; }
    .cr-card { background: var(--m-surface-2); border: 1px solid var(--m-border); border-radius: 10px; padding: 12px 8px; text-align: center; }
    .cr-val { display: block; font-size: 22px; font-weight: 800; }
    .cr-lbl { display: block; font-size: 10px; color: var(--m-text-2); margin-top: 3px; }
    .cr-active .cr-val { color: var(--m-primary); }
    .cr-ratio .cr-val { color: var(--m-positive); }
    .cr-section { background: var(--m-surface-2); border: 1px solid var(--m-border); border-radius: 10px; padding: 14px; margin-bottom: 12px; }
    .cr-section-title { font-size: 13px; font-weight: 700; color: var(--m-text); margin-bottom: 12px; display: flex; align-items: center; gap: 6px; }
    .cr-dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
    .cr-dot-long { background: var(--m-positive); }
    .cr-dot-short { background: var(--m-negative); }
    .cr-sig-card { display: flex; align-items: center; gap: 10px; background: rgba(255,255,255,0.04); border-radius: 8px; padding: 10px 12px; margin-bottom: 7px; border-left: 3px solid transparent; }
    .cr-sig-long { border-left-color: var(--m-positive); }
    .cr-sig-short { border-left-color: var(--m-negative); }
    .cr-dir { font-size: 11px; font-weight: 800; padding: 3px 8px; border-radius: 5px; min-width: 32px; text-align: center; flex-shrink: 0; }
    .cr-dir-long { background: rgba(var(--m-positive-rgb), 0.15); color: var(--m-positive); }
    .cr-dir-short { background: rgba(var(--m-negative-rgb), 0.15); color: var(--m-negative); }
    .cr-sig-asset { font-size: 13px; font-weight: 700; color: var(--m-text); min-width: 80px; flex-shrink: 0; }
    .cr-sig-code { font-size: 10px; color: var(--m-text-2); font-weight: 400; margin-left: 4px; }
    .cr-sig-meta { font-size: 11px; color: var(--m-text-2); flex: 1; min-width: 0; }
    .cr-sig-strat { color: var(--m-primary); font-weight: 600; }
    .cr-tags { margin-top: 3px; }
    .cr-tag { display: inline-block; padding: 1px 6px; border-radius: 3px; font-size: 10px; font-weight: 600; margin-right: 3px; }
    .cr-tag-reason { background: rgba(var(--m-primary-rgb), 0.15); color: var(--m-primary); }
    .cr-sig-actionable {
      display: block;
      font-size: 11px;
      color: var(--m-text-2);
      background: rgba(var(--m-primary-rgb), 0.06);
      border-left: 2px solid var(--m-primary);
      padding: 3px 8px;
      margin-bottom: 4px;
      border-radius: 0 4px 4px 0;
      line-height: 1.5;
    }
    .cr-tag-tier { background: rgba(var(--m-positive-rgb), 0.15); color: var(--m-positive); }
    .cr-conf { display: flex; flex-direction: column; align-items: flex-end; gap: 3px; min-width: 52px; flex-shrink: 0; }
    .cr-conf-val { font-size: 16px; font-weight: 800; }
    .cr-conf-bar { width: 48px; height: 4px; border-radius: 2px; background: var(--m-bg); overflow: hidden; }
    .cr-conf-fill { height: 100%; border-radius: 2px; }
    .cr-conf-high { background: var(--m-positive); }
    .cr-conf-med { background: var(--m-warn); }
    .cr-grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .cr-strat-row { display: flex; align-items: center; gap: 8px; padding: 8px 0; border-bottom: 1px solid var(--m-border); }
    .cr-strat-row:last-child { border-bottom: none; }
    .cr-strat-name { font-size: 11px; font-weight: 700; color: var(--m-text); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .cr-strat-count { font-size: 11px; color: var(--m-primary); font-weight: 700; flex-shrink: 0; }
    .cr-strat-ratio { font-size: 10px; color: var(--m-text-2); flex-shrink: 0; }
    .cr-heat-table { width: 100%; border-collapse: collapse; }
    .cr-heat-table th { text-align: left; padding: 6px 8px; border-bottom: 2px solid var(--m-border); color: var(--m-text-2); font-size: 10px; font-weight: 600; }
    .cr-heat-table td { padding: 8px; border-bottom: 1px solid var(--m-border); font-weight: 700; text-align: center; font-size: 13px; }
    .cr-heat-label { text-align: left !important; font-size: 11px; color: var(--m-text); }
    .cr-heat-hot { background: rgba(var(--m-positive-rgb), 0.1); color: var(--m-positive); }
    .cr-heat-warm { background: rgba(var(--m-warn-rgb), 0.1); color: var(--m-warn); }
    .cr-heat-cold { background: var(--m-surface-2); color: var(--m-text-2); }
    .cr-ico { font-size: 15px; }
    .cr-event-card { display: flex; flex-direction: column; gap: 6px; padding: 10px 0; border-bottom: 1px solid var(--m-border); }
    .cr-event-card:last-child { border-bottom: none; }
    .cr-event-row { display: flex; gap: 10px; align-items: flex-start; }
    .cr-event-pic { width: 42px; height: 42px; border-radius: 6px; object-fit: cover; flex-shrink: 0; background: var(--m-surface-2); }
    .cr-event-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
    .cr-event-title { font-size: 13px; color: var(--m-text); font-weight: 600; line-height: 1.4; }
    .cr-event-thesis { font-size: 11px; color: var(--m-text-2); line-height: 1.4; margin-top: 2px; }
    .cr-event-source { font-size: 10px; color: var(--m-text-3); }
    .cr-event-tickers { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 2px; }
    .cr-ticker-tag { font-size: 10px; background: rgba(var(--m-primary-rgb), 0.12); color: var(--m-primary); padding: 2px 6px; border-radius: 4px; white-space: nowrap; }
    .cr-hot-card { padding: 12px 0; border-bottom: 1px solid var(--m-border); }
    .cr-hot-card:last-child { border-bottom: none; }
    .cr-hot-label { font-size: 10px; font-weight: 700; color: var(--m-warn); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .cr-hot-summary { font-size: 13px; color: var(--m-text); font-weight: 600; line-height: 1.5; margin-bottom: 4px; }
    .cr-hot-source { font-size: 10px; color: var(--m-text-3); margin-bottom: 6px; }
    .cr-event-tickers-v43 { display: flex; flex-direction: column; gap: 3px; margin-top: 4px; }
    .cr-ticker-item { font-size: 11px; color: var(--m-text); padding: 3px 6px; background: rgba(var(--m-positive-rgb), 0.08); border-radius: 4px; display: inline-block; }
    .cr-ticker-reason { font-size: 10px; color: var(--m-text-2); }
    .cr-sig-expandable { cursor: pointer; transition: background 0.15s; position: relative; }
    .cr-sig-expandable:hover { background: rgba(255,255,255,0.05); }
    .cr-sig-expandable::after {
      content: '\25BE'; font-size: 10px; color: var(--m-text-3);
      position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
      transition: transform 0.2s;
    }
    .cr-sig-expanded .cr-sig-meta { overflow: visible; white-space: normal; }
    .cr-sig-expandable.cr-sig-expanded::after { transform: translateY(-50%) rotate(180deg); }
    .cr-sig-detail { display: none; }
    .cr-sig-expanded .cr-sig-detail { display: block; margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--m-border); }
    .cr-detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
    .cr-detail-cell { padding: 6px 8px; background: var(--m-bg); border-radius: 6px; }
    .cr-detail-lbl { font-size: 9px; color: var(--m-text-3); text-transform: uppercase; letter-spacing: 0.5px; }
    .cr-detail-val { font-size: 12px; color: var(--m-text); font-weight: 700; margin-top: 2px; }
    .cr-detail-expiry-ok { color: var(--m-positive); }
    .cr-detail-expiry-warn { color: var(--m-warn); }
    .cr-detail-expiry-expired { color: var(--m-negative); }
    .cr-all-tags { margin-top: 8px; display: flex; flex-wrap: wrap; gap: 4px; }
    .cr-dir-reason { margin-top: 10px; padding: 10px; background: rgba(var(--m-positive-rgb), 0.06); border-radius: 8px; border-left: 3px solid rgba(var(--m-positive-rgb), 0.3); }
    .cr-dir-reason-label { font-size: 11px; font-weight: 700; color: var(--m-text); margin-bottom: 6px; }
    .cr-dir-reason-item { font-size: 11px; color: var(--m-text); line-height: 1.6; padding: 2px 0; }
    .cr-rec-badge { display: inline-block; margin-left: 8px; padding: 2px 8px; border-radius: 10px; background: linear-gradient(135deg, var(--m-warn), var(--m-negative)); color: #fff; font-size: 10px; font-weight: 700; letter-spacing: 0.5px; vertical-align: middle; }
    .cr-summary-card { background: linear-gradient(135deg, rgba(var(--m-primary-rgb), 0.15) 0%, rgba(var(--m-primary-rgb), 0.08) 100%); border: 1px solid rgba(var(--m-primary-rgb), 0.2); border-radius: 10px; padding: 16px; margin-bottom: 16px; }
    .cr-summary-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 12px; }
    .cr-summary-regime { font-size: 20px; font-weight: 800; letter-spacing: 1px; }
    .cr-summary-regime.offense { color: var(--m-positive); }
    .cr-summary-regime.defense { color: var(--m-negative); }
    .cr-summary-regime.balance { color: var(--m-warn); }
    .cr-summary-action { font-size: 11px; padding: 3px 10px; border-radius: 12px; font-weight: 600; }
    .cr-summary-action.offense { background: rgba(var(--m-positive-rgb), 0.15); color: var(--m-positive); }
    .cr-summary-action.defense { background: rgba(var(--m-negative-rgb), 0.15); color: var(--m-negative); }
    .cr-summary-action.balance { background: rgba(var(--m-warn-rgb), 0.15); color: var(--m-warn); }
    .cr-summary-conf { font-size: 12px; font-weight: 700; color: var(--m-warn); margin-left: 6px; }
    .cr-summary-stats { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 8px; }
    .cr-summary-stat { text-align: center; }
    .cr-summary-stat-val { font-size: 18px; font-weight: 800; color: var(--m-text); }
    .cr-summary-stat-lbl { font-size: 9px; color: var(--m-text-3); margin-top: 2px; }
    .cr-summary-thesis { margin-top: 10px; padding-top: 10px; border-top: 1px solid rgba(var(--m-primary-rgb), 0.2); font-size: 11px; color: var(--m-text-2); line-height: 1.5; }
    .cr-freshness { display: flex; align-items: center; gap: 8px; padding: 8px 12px; background: var(--m-surface-2); border-left: 3px solid var(--m-text-3); border-radius: 6px; margin-bottom: 12px; font-size: 12px; }
    .cr-freshness-icon { font-size: 13px; flex-shrink: 0; }
    .cr-freshness-label { color: var(--m-text); font-weight: 600; }
    .cr-freshness-time { color: var(--m-text-3); font-size: 10px; margin-left: auto; }
    .cr-stats-bar { display: flex; justify-content: center; align-items: center; gap: 6px; padding: 10px 12px; margin-bottom: 12px; background: linear-gradient(135deg, rgba(var(--m-primary-rgb), 0.12) 0%, rgba(var(--m-primary-rgb), 0.08) 100%); border: 1px solid rgba(var(--m-primary-rgb), 0.2); border-radius: 10px; flex-wrap: wrap; }
    .cr-stat-item { display: flex; flex-direction: column; align-items: center; min-width: 52px; }
    .cr-stat-val { font-size: 18px; font-weight: 800; color: var(--m-text); line-height: 1.2; }
    .cr-stat-label { font-size: 9px; color: var(--m-text-3); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.3px; }
    .cr-stat-sep { color: rgba(255,255,255,0.1); font-size: 14px; margin: 0 4px; }
    .cr-risk-warnings { margin-top: 10px; display: flex; flex-direction: column; gap: 5px; }
    .cr-risk-item { font-size: 11px; color: var(--m-warn); line-height: 1.5; padding: 4px 10px; background: rgba(var(--m-warn-rgb), 0.08); border-left: 3px solid var(--m-warn); border-radius: 0 6px 6px 0; }
    .cr-en-block { margin-bottom: 14px; }
    .cr-en-header { background: linear-gradient(135deg, rgba(var(--m-primary-rgb), 0.12) 0%, rgba(var(--m-primary-rgb), 0.06) 100%); border: 1px solid rgba(var(--m-primary-rgb), 0.2); border-radius: 10px; padding: 14px 16px; margin-bottom: 10px; }
    .cr-en-header .cr-summary-regime { font-size: 16px; }
    .cr-en-thesis { margin-top: 8px; font-size: 12px; color: var(--m-text); line-height: 1.6; }
    .cr-en-fresh { margin-top: 6px; font-size: 10px; color: var(--m-text-3); }
    .cr-en-events { }
    .ev-card { background: rgba(255,255,255,0.04); border-radius: 8px; padding: 10px 12px; margin: 8px 0; border-left: 3px solid var(--m-primary); }
    .ev-header { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; margin-bottom: 5px; }
    .ev-rank { font-size: 11px; font-weight: 700; color: var(--m-primary); background: rgba(var(--m-primary-rgb), 0.15); padding: 2px 6px; border-radius: 3px; flex-shrink: 0; }
    .ev-title { font-size: 13px; font-weight: 700; color: var(--m-text); flex: 1; min-width: 0; }
    .ev-decay { font-size: 10px; color: var(--m-text-3); background: var(--m-surface-2); padding: 1px 5px; border-radius: 3px; flex-shrink: 0; } /* deprecated, see .ev-time */
    .ev-interp { font-size: 12px; color: var(--m-text-2); line-height: 1.55; margin-bottom: 6px; }
    .ev-time { font-size: 10px; color: var(--m-text-3); background: var(--m-surface-2); padding: 1px 6px; border-radius: 3px; flex-shrink: 0; }
    .ev-label { font-size: 9px; font-weight: 700; color: var(--m-primary); margin-right: 6px; flex-shrink: 0; }
    .ev-trigger { font-size: 12px; color: var(--m-text-2); line-height: 1.55; margin: 6px 0 4px; }
    .ev-reaction { font-size: 12px; color: #fde68a; line-height: 1.55; margin-bottom: 4px; background: rgba(253,230,138,0.06); padding: 3px 0; }
    .ev-detail { margin: 5px 0; padding: 6px 8px; background: rgba(255,255,255,0.02); border-radius: 6px; }
    .ev-valuation { font-size: 11px; color: var(--m-text-2); line-height: 1.5; margin-bottom: 3px; }
    .ev-trading { font-size: 11px; color: var(--m-text-2); line-height: 1.5; }
    .ev-stock-type { font-size: 9px; font-weight: 700; padding: 1px 4px; border-radius: 2px; margin-right: 4px; }
    .ev-stock-type.st-benefit { background: rgba(var(--m-positive-rgb), 0.18); color: var(--m-positive); }
    .ev-stock-type.st-elastic { background: rgba(245,158,11,0.18); color: #fbbf24; }
    .ev-stock-type.st-other { background: rgba(255,255,255,0.06); color: var(--m-text-2); }
    .ev-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 5px; }
    .ev-tag { font-size: 10px; padding: 2px 7px; border-radius: 3px; font-weight: 600; }
    .ev-tag.bull { background: rgba(var(--m-positive-rgb), 0.12); color: var(--m-positive); }
    .ev-tag.bear { background: rgba(var(--m-negative-rgb), 0.12); color: var(--m-negative); }
    .ev-tag.neutral { background: rgba(255,255,255,0.05); color: var(--m-text-2); }
    .ev-source { font-size: 10px; color: var(--m-text-3); }
    .ev-stocks { display: flex; flex-wrap: wrap; gap: 5px; margin: 5px 0 4px; }
    .ev-stock { font-size: 11px; color: var(--m-text); background: rgba(255,255,255,0.04); padding: 2px 7px; border-radius: 4px; border: 1px solid var(--m-border); cursor: pointer; user-select: none; }
    .ev-stock small { color: var(--m-text-2); font-size: 10px; margin-left: 2px; }
    .ev-stock:hover { background: rgba(var(--m-primary-rgb), 0.15); border-color: var(--m-primary); }
    .ev-stock.expanded { background: rgba(var(--m-primary-rgb), 0.15); border-color: var(--m-primary); }
    .ev-stock-more { font-size: 10px; color: var(--m-primary); padding: 2px 6px; align-self: center; }
    .ev-stock-reason { display: none; font-size: 10px; color: var(--m-text-2); margin-top: 3px; padding: 3px 6px; background: rgba(var(--m-primary-rgb), 0.08); border-left: 2px solid var(--m-primary); border-radius: 0 3px 3px 0; box-sizing: border-box; }
    </style>
</head>
<body>
<div class="app-header">
  <span class="app-title">☀️ <%= title %></span>
  <span class="app-version"><%= appVersion || 'V6.5' %></span>
</div>
<div class="m-tabs">
  <div class="m-tab active" data-tab="overview">📊 概览</div>
  <div class="m-tab" data-tab="watchlist">📱 自选</div>
  <div class="m-tab" data-tab="cycleradar">📡 信号</div>
  <div class="m-tab" data-tab="article">📝 文章</div>
</div>
<div class="m-content">
  <div class="m-panel active" id="p-overview">
    <div id="overview-loading" class="loading"><div class="spin"></div></div>
    <div id="overview-content" style="display:none"></div>
  </div>
  <div class="m-panel" id="p-watchlist">
    <div id="wl-loading" class="loading"><div class="spin"></div></div>
    <div id="wl-content" style="display:none"></div>
  </div>
  <div class="m-panel" id="p-cycleradar">
    <div id="cr-loading" class="loading"><div class="spin"></div></div>
    <div id="cr-content" style="display:none"></div>
  </div>
  <div class="m-panel" id="p-article">
    <div id="art-loading" class="loading"><div class="spin"></div></div>
    <div id="art-content" style="display:none"></div>
  </div>
</div>
<div class="refresh-bar">数据更新 <span onclick="refreshAll()">🔄 刷新</span></div>
<div class="modal-overlay" id="stock-modal" onclick="closeModal()">
  <div class="modal-card" onclick="event.stopPropagation()">
    <span class="modal-close" onclick="closeModal()">✕</span>
    <div id="modal-content"></div>
  </div>
</div>
<script src="/mobile-assets/app.js?v=<%= appVersion %>"></script>
</body>
</html>
