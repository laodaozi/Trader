<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <meta http-equiv="refresh" content="3600">
  <title>交易仪表盘 V6</title>
  <style>
    /* ===== Design Tokens · /m Mobile ===== */
    :root {
      --m-bg:        #0a0e1a;
      --m-surface:   #111827;
      --m-surface-2: #1e293b;
      --m-border:    #1e293b;
      --m-primary:   #3b82f6;
      --m-positive:  #10b981;
      --m-negative:  #ef4444;
      --m-warn:      #f59e0b;
      --m-text:      #e2e8f0;
      --m-text-2:    #94a3b8;
      --m-text-3:    #64748b;
      --m-etf:       #a78bfa;
      --m-mono: "JetBrains Mono", "SF Mono", Menlo, monospace;
    }

    /* ===== Base ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow-x: hidden; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
      background: var(--m-bg); color: var(--m-text);
      -webkit-font-smoothing: antialiased;
    }
    #app { max-width: 480px; margin: 0 auto; padding: 12px 12px 60px; }

    /* ===== Header ===== */
    header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 8px 0 10px; border-bottom: 1px solid var(--m-border); margin-bottom: 10px;
    }
    .header-left { display: flex; align-items: center; gap: 8px; }
    .header-title { font-size: 15px; font-weight: 700; color: var(--m-text); letter-spacing: 1px; font-family: var(--m-mono); }
    .header-right { display: flex; align-items: center; gap: 8px; }
    .market-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--m-positive); display: inline-block; }
    .header-date { font-size: 11px; color: var(--m-text-3); font-family: var(--m-mono); }
    .version-tag { font-size: 9px; color: var(--m-text-3); font-family: var(--m-mono); border: 1px solid var(--m-border); padding: 1px 5px; border-radius: 3px; }

    /* ===== Tab Bar ===== */
    .tab-bar {
      display: flex; background: var(--m-surface); border-radius: 6px;
      padding: 3px; margin-bottom: 12px; gap: 2px;
    }
    .tab-btn {
      flex: 1; padding: 8px 6px; border: none; background: transparent;
      color: var(--m-text-3); font-size: 12px; font-weight: 500; border-radius: 4px;
      cursor: pointer; transition: background 0.15s, color 0.15s; white-space: nowrap;
    }
    .tab-btn.active { background: var(--m-surface-2); color: var(--m-primary); font-weight: 600; }

    /* ===== Tab Panels ===== */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ===== Cards ===== */
    .card {
      background: var(--m-surface); border: 1px solid var(--m-border);
      border-radius: 8px; padding: 14px; margin-bottom: 10px;
    }
    .card-label { font-size: 10px; font-weight: 600; color: var(--m-text-3); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
    .card h2 { font-size: 13px; font-weight: 600; color: var(--m-text-2); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 10px; }

    /* ===== Loading / Error / Empty ===== */
    .loading { text-align: center; padding: 40px 0; color: var(--m-text-3); font-size: 13px; }
    .err { padding: 20px; color: var(--m-negative); font-size: 13px; background: rgba(239,68,68,0.06); border-radius: 6px; border-left: 3px solid var(--m-negative); }
    .node { text-align: center; padding: 32px 0; color: var(--m-text-3); font-size: 13px; }

    /* ===== 温度仪表盘 ===== */
    .gauge-wrap { display: flex; align-items: center; gap: 16px; padding: 4px 0 12px; }
    .gauge-score {
      font-family: var(--m-mono); font-size: 56px; font-weight: 700;
      line-height: 1; min-width: 80px;
    }
    .gauge-right { flex: 1; }
    .gauge-phase { font-size: 13px; font-weight: 600; color: var(--m-text); margin-bottom: 4px; }
    .gauge-advice { font-size: 11px; color: var(--m-text-3); margin-bottom: 10px; }
    .gauge-bar-track { height: 6px; background: var(--m-bg); border-radius: 3px; overflow: hidden; }
    .gauge-bar-fill { height: 100%; border-radius: 3px; transition: width 0.6s ease; background: linear-gradient(90deg, var(--m-primary), var(--m-warn), var(--m-negative)); background-size: 300% 100%; }
    .gauge-ticks { display: flex; justify-content: space-between; margin-top: 4px; }
    .gauge-ticks span { font-size: 9px; color: var(--m-text-3); font-family: var(--m-mono); }
    .gauge-ticks .t-cur { color: var(--m-primary); font-weight: 700; }

    /* ===== 今日研判 ===== */
    .narrative {
      font-size: 13px; line-height: 1.75; color: var(--m-text-2);
      border-left: 2px solid var(--m-primary); padding-left: 12px;
      margin: 0;
    }

    /* ===== 信号摘要横排 ===== */
    .sig-summary { display: flex; gap: 0; border: 1px solid var(--m-border); border-radius: 6px; overflow: hidden; margin-bottom: 10px; }
    .sig-summary-item { flex: 1; text-align: center; padding: 10px 6px; border-right: 1px solid var(--m-border); }
    .sig-summary-item:last-child { border-right: none; }
    .sig-summary-num { font-family: var(--m-mono); font-size: 28px; font-weight: 700; line-height: 1; }
    .sig-summary-lbl { font-size: 9px; color: var(--m-text-3); text-transform: uppercase; letter-spacing: 0.8px; margin-top: 3px; }

    /* ===== 信号行（行情列表风格）===== */
    .signal-row { display: flex; align-items: center; justify-content: space-between; padding: 7px 0; border-bottom: 1px solid var(--m-border); }
    .signal-row:last-child { border-bottom: none; }
    .sig-left { display: flex; flex-direction: column; gap: 1px; }
    .sig-name { font-size: 13px; font-weight: 600; color: var(--m-text); }
    .sig-code { font-size: 10px; color: var(--m-text-3); font-family: var(--m-mono); }
    .sig-right { display: flex; align-items: center; gap: 8px; }
    .sig-score { font-family: var(--m-mono); font-size: 16px; font-weight: 700; min-width: 36px; text-align: right; }

    /* ===== Badges ===== */
    .badge { display: inline-block; font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 3px; white-space: nowrap; letter-spacing: 0.5px; }
    .badge-bull { background: rgba(16,185,129,0.15); color: var(--m-positive); }
    .badge-bear { background: rgba(239,68,68,0.15); color: var(--m-negative); }
    .badge-warn { background: rgba(245,158,11,0.15); color: var(--m-warn); }
    .badge-info { background: rgba(59,130,246,0.12); color: var(--m-primary); }
    .badge-muted { background: rgba(148,163,184,0.1); color: var(--m-text-3); }

    /* ===== 自选持仓行 ===== */
    .wl-row {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 0; border-bottom: 1px solid var(--m-border);
    }
    .wl-row:last-child { border-bottom: none; }
    .wl-left { display: flex; flex-direction: column; gap: 2px; }
    .wl-name { font-size: 14px; font-weight: 600; color: var(--m-text); }
    .wl-code { font-size: 10px; color: var(--m-text-3); font-family: var(--m-mono); }
    .wl-right { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
    .wl-zone { display: flex; gap: 12px; margin-top: 6px; }
    .wl-zone-item { font-size: 11px; }
    .wl-zone-label { color: var(--m-text-3); margin-right: 3px; }
    .wl-zone-val { color: var(--m-text); font-weight: 600; font-family: var(--m-mono); }
    .wl-thesis { font-size: 11px; color: var(--m-text-3); line-height: 1.5; padding-top: 6px; border-top: 1px solid var(--m-border); margin-top: 6px; }

    /* ===== 信号表格（紧凑行情表）===== */
    .cyra-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .cyra-table th { text-align: left; color: var(--m-text-3); font-size: 9px; font-weight: 600; padding: 6px 6px; border-bottom: 1px solid var(--m-border); text-transform: uppercase; letter-spacing: 0.5px; }
    .cyra-table td { padding: 8px 6px; border-bottom: 1px solid var(--m-border); color: var(--m-text); }
    .cyra-table tr:last-child td { border-bottom: none; }
    .cyra-table tr:active td { background: rgba(59,130,246,0.05); }
    .col-sig { font-weight: 600; }
    .col-code { font-family: var(--m-mono); font-size: 10px; color: var(--m-text-3); }
    .col-conf { text-align: right; font-family: var(--m-mono); font-weight: 700; }
    .cyra-confidence-1 { color: var(--m-negative); }
    .cyra-confidence-2 { color: var(--m-warn); }
    .cyra-confidence-3 { color: var(--m-primary); }
    .cyra-confidence-4 { color: var(--m-positive); }

    /* ===== 底部状态栏 ===== */
    #status-bar {
      position: fixed; bottom: 0; left: 0; right: 0; height: 40px;
      background: var(--m-surface); border-top: 1px solid var(--m-border);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 14px; z-index: 50;
    }
    #status-text { font-size: 11px; color: var(--m-text-3); }
    #status-timer { font-family: var(--m-mono); font-size: 11px; color: var(--m-text-3); }
    #refresh-btn {
      background: none; border: 1px solid var(--m-border); color: var(--m-text-3);
      padding: 3px 10px; border-radius: 4px; font-size: 10px; cursor: pointer; font-family: var(--m-mono);
    }
    #refresh-btn:active { background: var(--m-surface-2); }

    /* ===== 事件列表 ===== */
    .event-row { padding: 6px 0; border-bottom: 1px solid var(--m-border); display: flex; gap: 8px; align-items: baseline; }
    .event-row:last-child { border-bottom: none; }
    .event-rank { font-family: var(--m-mono); font-size: 10px; color: var(--m-text-3); min-width: 18px; }
    .event-title { font-size: 12px; color: var(--m-text-2); line-height: 1.4; }

    /* ===== Responsive ===== */
    @media (max-width: 480px) {
      #app { padding: 10px 10px 56px; }
      .gauge-score { font-size: 44px; }
    }
  </style>
</head>
<body>
<div id="app">
  <header>
    <div class="header-left">
      <span class="market-dot" id="market-dot"></span>
      <span class="header-title">CYCLERADAR</span>
    </div>
    <div class="header-right">
      <span class="header-date" id="header-date"></span>
      <span class="version-tag">V6.2</span>
    </div>
  </header>

  <nav class="tab-bar">
    <button class="tab-btn active" data-tab="overview">概览</button>
    <button class="tab-btn" data-tab="watchlist">自选</button>
    <button class="tab-btn" data-tab="cycleradar">信号</button>
    <button class="tab-btn" data-tab="reflection">🧠反思</button>
  </nav>

  <div id="panel-overview" class="tab-panel active"></div>
  <div id="panel-watchlist" class="tab-panel">
    <p class="loading">加载中…</p>
  </div>
  <div id="panel-reflection" class="tab-panel"><p class="loading">加载中…</p></div>
  <div id="panel-cycleradar" class="tab-panel">
    <p class="loading">加载中…</p>
  </div>

  <div id="status-bar">
    <span id="status-text">就绪</span>
    <span id="status-timer">--:--:--</span>
    <button id="refresh-btn" onclick="refreshAll()">刷新</button>
  </div>
</div>

<!-- Stock Detail Popup -->
<div id="popup" class="popup-overlay" onclick="if(event.target===this)closePopup()">
  <div class="popup-content">
    <span class="popup-close" onclick="closePopup()">&times;</span>
    <div id="popup-body"></div>
    <div class="popup-actions" id="popup-actions"></div>
  </div>
</div>

<script>
// ── V6 Dashboard JS ──────────────────────────────────────────
const API = {
  summary:    '/m/api/summary',
  cycleradar: '/m/api/cycleradar',
  watchlist:  '/m/api/watchlist',
  reflection: '/m/api/strategy-reflection',
};

let _cache = {};

async function fetchJSON(url) {
  if (_cache[url]) return _cache[url];
  const r = await fetch(url);
  if (!r.ok) throw new Error(`${url} → ${r.status}`);
  const d = await r.json();
  _cache[url] = d;
  return d;
}

// ── Tab 切换 ────────────────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    const tab = btn.dataset.tab;
    document.getElementById('panel-' + tab).classList.add('active');
    loadTab(tab);
  });
});

// ── 路由 ────────────────────────────────────────────────────
function loadTab(tab) {
  if (tab === 'overview')    loadOverview();
  if (tab === 'watchlist')   loadWatchlist();
  if (tab === 'cycleradar')  loadCycleradar();
  if (tab === 'reflection')  loadReflection();
}

// ── 工具函数 ─────────────────────────────────────────────────
function pct(v) {
  if (v == null) return '--';
  const n = parseFloat(v);
  const s = (n >= 0 ? '+' : '') + n.toFixed(2) + '%';
  return `<span style="color:${n >= 0 ? 'var(--m-positive)' : 'var(--m-negative)'}">${s}</span>`;
}
function fmt(v, digits=2) { return v == null ? '--' : parseFloat(v).toFixed(digits); }
function badge(text, cls) { return `<span class="badge badge-${cls}">${text}</span>`; }
function el(id) { return document.getElementById(id); }
function html(id, s) { const e = document.getElementById(id); if(e) e.innerHTML = s; }

// ── 概览 Tab ─────────────────────────────────────────────────
async function loadOverview() {
  const panel = el('panel-overview');
  if (panel.dataset.loaded) return;
  panel.innerHTML = '<p class="loading">加载中…</p>';
  try {
    const [sum, cr] = await Promise.all([fetchJSON(API.summary), fetchJSON(API.cycleradar)]);
    panel.dataset.loaded = '1';

    const t = sum.timing || {};
    const score = t.temperature != null ? Math.round(t.temperature) : '--';
    const phase = t.phase || '未知';
    const advice = t.advice || '';
    const fillW = score === '--' ? 0 : Math.min(100, score);
    // 颜色：冷(蓝)→暖(橙)→热(红)
    const scoreColor = score >= 75 ? 'var(--m-negative)' : score >= 50 ? 'var(--m-warn)' : 'var(--m-positive)';

    // 今日研判
    const ev = sum.event_narrative || {};
    const gcRaw = ev.global_conclusion;
    const gc = (gcRaw && typeof gcRaw === 'object') ? gcRaw : {};
    const gcText = (typeof gcRaw === 'string') ? gcRaw : '';
    const regime = gc.market_regime || '--';
    const action = gc.action_bias || gc.market_action || '--';
    const thesis = gc.thesis || gc.investment_thesis || gcText || '';
    const events = ev.events || [];

    const alpha = cr.alpha || [];
    const etf   = cr.etf   || [];
    const comm  = cr.commodity || [];

    // 更新市场状态点颜色
    const dot = el('market-dot');
    if (dot) dot.style.background = scoreColor;

    panel.innerHTML = `
      <!-- 温度仪表盘 -->
      <div class="card">
        <div class="card-label">市场温度</div>
        <div class="gauge-wrap">
          <div class="gauge-score" style="color:${scoreColor}">${score}</div>
          <div class="gauge-right">
            <div class="gauge-phase">${phase}</div>
            <div class="gauge-advice">${advice || '暂无建议'}</div>
            <div class="gauge-bar-track">
              <div class="gauge-bar-fill" style="width:${fillW}%;background-position:${fillW}% 0"></div>
            </div>
            <div class="gauge-ticks">
              <span>0</span>
              <span class="t-cur">${score}</span>
              <span>100</span>
            </div>
          </div>
        </div>
      </div>

      <!-- 信号摘要 -->
      <div class="sig-summary">
        <div class="sig-summary-item">
          <div class="sig-summary-num" style="color:var(--m-primary)">${alpha.length}</div>
          <div class="sig-summary-lbl">Alpha</div>
        </div>
        <div class="sig-summary-item">
          <div class="sig-summary-num" style="color:var(--m-etf)">${etf.length}</div>
          <div class="sig-summary-lbl">ETF</div>
        </div>
        <div class="sig-summary-item">
          <div class="sig-summary-num" style="color:var(--m-warn)">${comm.length}</div>
          <div class="sig-summary-lbl">商品</div>
        </div>
      </div>

      <!-- 今日研判 -->
      ${thesis ? `
      <div class="card">
        <div class="card-header">
          <div class="card-label" style="margin-bottom:0">今日研判</div>
          ${regime !== '--' ? badge(regime, regime.includes('进攻')||regime.includes('多')?'bull':regime.includes('防')||regime.includes('避')?'bear':'info') : ''}
        </div>
        <div class="narrative">${thesis}</div>
        ${events.length ? `<div style="margin-top:10px">${events.slice(0,6).map(e=>`
          <div class="event-row">
            <span class="event-rank">#${e.rank||'?'}</span>
            <span class="event-title">${e.event||e.title||''}</span>
          </div>`).join('')}</div>` : ''}
      </div>` : ''}

      <!-- Top Alpha -->
      ${alpha.length ? `
      <div class="card">
        <div class="card-label">Alpha Top ${Math.min(alpha.length,8)}</div>
        ${alpha.slice(0,8).map(s => {
          const conf = Math.round((s.confidence||0)*100);
          const name = s.asset_name||(s.metadata&&s.metadata.stock_name)||s.asset;
          const confColor = conf>=80?'var(--m-positive)':conf>=65?'var(--m-primary)':'var(--m-text-3)';
          return `<div class="signal-row">
            <div class="sig-left">
              <span class="sig-name">${name}</span>
              <span class="sig-code">${s.asset}</span>
            </div>
            <div class="sig-right">
              ${badge(s.direction==='long'?'多':'空',s.direction==='long'?'bull':'bear')}
              <span class="sig-score" style="color:${confColor}">${conf}</span>
            </div>
          </div>`;
        }).join('')}
      </div>` : ''}
    `;
  } catch(e) {
    panel.innerHTML = `<div class="err">概览加载失败：${e.message}</div>`;
  }
}

// ── 自选 Tab ─────────────────────────────────────────────────
async function loadWatchlist() {
  const panel = el('panel-watchlist');
  if (panel.dataset.loaded) return;
  panel.innerHTML = '<p class="loading">加载中…</p>';
  try {
    const data = await fetchJSON(API.watchlist);
    panel.dataset.loaded = '1';
    const stocks = data.stocks || data || [];
    const signals = data.signals || [];
    const sigMap = {};
    signals.forEach(s => { sigMap[s.asset] = s; });

    if (!stocks.length) {
      panel.innerHTML = '<div class="node">自选池为空，前往 Admin → 自选股 添加</div>';
      return;
    }

    panel.innerHTML = `<div class="card">${stocks.map(s => {
      const code = s.code || s.stock_code || '';
      const name = s.name || s.stock_name || code;
      const sig  = sigMap[code] || null;
      const conf = sig ? Math.round((sig.confidence||0)*100) : null;
      const dir  = sig ? sig.direction : null;
      const entry  = sig?.metadata?.entry_price;
      const target = sig?.metadata?.target_price;
      const stop   = sig?.metadata?.stop_loss;
      const thesis = sig?.metadata?.thesis;
      const confColor = conf>=80?'var(--m-positive)':conf>=65?'var(--m-primary)':'var(--m-text-3)';

      return `<div class="wl-row">
        <div class="wl-left">
          <span class="wl-name">${name}</span>
          <span class="wl-code">${code}</span>
          ${(entry||target||stop) ? `<div class="wl-zone">
            ${entry  ? `<span class="wl-zone-item"><span class="wl-zone-label">入</span><span class="wl-zone-val">${fmt(entry)}</span></span>` : ''}
            ${target ? `<span class="wl-zone-item"><span class="wl-zone-label">目</span><span class="wl-zone-val">${fmt(target)}</span></span>` : ''}
            ${stop   ? `<span class="wl-zone-item"><span class="wl-zone-label">损</span><span class="wl-zone-val">${fmt(stop)}</span></span>` : ''}
          </div>` : ''}
          ${thesis ? `<div class="wl-thesis">${thesis}</div>` : ''}
        </div>
        <div class="wl-right">
          ${sig ? badge(dir==='long'?'多':'空',dir==='long'?'bull':'bear') : badge('待机','muted')}
          ${conf!=null ? `<span style="font-family:var(--m-mono);font-size:18px;font-weight:700;color:${confColor}">${conf}</span>` : ''}
        </div>
      </div>`;
    }).join('')}</div>`;
  } catch(e) {
    panel.innerHTML = `<div class="err">自选加载失败：${e.message}</div>`;
  }
}

// ── 信号 Tab ─────────────────────────────────────────────────
async function loadCycleradar() {
  const panel = el('panel-cycleradar');
  if (panel.dataset.loaded) return;
  panel.innerHTML = '<p class="loading">加载中…</p>';
  try {
    const cr = await fetchJSON(API.cycleradar);
    panel.dataset.loaded = '1';
    const alpha = cr.alpha || [];
    const etf   = cr.etf   || [];
    const comm  = cr.commodity || [];

    const renderTable = (rows, cols) => {
      if (!rows.length) return '<div class="node" style="padding:16px 0">暂无信号</div>';
      return `<table class="cyra-table">
        <thead><tr>${cols.map(c=>`<th>${c}</th>`).join('')}</tr></thead>
        <tbody>${rows.join('')}</tbody>
      </table>`;
    };

    const alphaRows = alpha.slice(0,30).map(s => {
      const conf = Math.round((s.confidence||0)*100);
      const cls  = conf>=80?'cyra-confidence-4':conf>=70?'cyra-confidence-3':conf>=60?'cyra-confidence-2':'cyra-confidence-1';
      const name = s.asset_name||(s.metadata&&s.metadata.stock_name)||s.asset;
      return `<tr>
        <td class="col-sig">${name}</td>
        <td class="col-code">${s.asset}</td>
        <td>${badge(s.direction==='long'?'多':'空',s.direction==='long'?'bull':'bear')}</td>
        <td class="col-conf ${cls}">${conf}</td>
      </tr>`;
    });

    const etfRows = etf.slice(0,20).map(s => `<tr>
      <td class="col-sig">${s.asset_name||(s.metadata&&s.metadata.stock_name)||s.asset}</td>
      <td class="col-code">${(s.metadata&&s.metadata.etf_code)||s.asset}</td>
      <td>${badge(s.direction==='long'?'多':'空',s.direction==='long'?'bull':'bear')}</td>
      <td class="col-conf">${Math.round((s.confidence||0)*100)}</td>
    </tr>`);

    const commRows = comm.slice(0,15).map(s => {
      const conf = Math.round((s.confidence||0)*100);
      const cls  = conf>=70?'cyra-confidence-4':'cyra-confidence-2';
      return `<tr>
        <td class="col-sig">${s.asset_name||s.asset}</td>
        <td>${badge(s.direction==='long'?'多':'空',s.direction==='long'?'bull':'bear')}</td>
        <td class="col-conf ${cls}">${conf}</td>
      </tr>`;
    });

    panel.innerHTML = `
      <div class="card">
        <div class="card-label">Alpha · ${alpha.length} 条</div>
        ${renderTable(alphaRows, ['名称','代码','方向','置信'])}
      </div>
      <div class="card">
        <div class="card-label">ETF / 板块 · ${etf.length} 条</div>
        ${renderTable(etfRows, ['板块','ETF','方向','置信'])}
      </div>
      <div class="card">
        <div class="card-label">商品 · ${comm.length} 条</div>
        ${renderTable(commRows, ['品种','方向','置信'])}
      </div>`;
  } catch(e) {
    panel.innerHTML = `<div class="err">信号加载失败：${e.message}</div>`;
  }
}

// ── 状态栏时钟 ───────────────────────────────────────────────
function updateClock() {
  const now = new Date();
  const s = now.toTimeString().slice(0,8);
  const t = el('status-timer'); if(t) t.textContent = s;
}
setInterval(updateClock, 1000);
updateClock();

// ── 全局刷新 ─────────────────────────────────────────────────
function refreshAll() {
  _cache = {};
  document.querySelectorAll('.tab-panel').forEach(p => delete p.dataset.loaded);
  const active = document.querySelector('.tab-btn.active');
  if (active) loadTab(active.dataset.tab);
  html('status-text', '已刷新 ' + new Date().toTimeString().slice(0,5));
}

// ── 初始化 ───────────────────────────────────────────────────
// Header 日期
const hd = el('header-date');
if (hd) hd.textContent = new Date().toLocaleDateString('zh-CN', {month:'2-digit',day:'2-digit',weekday:'short'}).replace(/\//g,'-');
loadOverview();

// ── 策略反思 Tab ───────────────────────────────────────────
async function loadReflection() {
  const panel = document.getElementById('panel-reflection');
  try {
    const d = await fetchJSON(API.reflection);
    if (!d.reflections || !d.reflections.length) {
      panel.innerHTML = '<div class="card"><p>' + escHtml(d.summary || '暂无数据') + '</p></div>';
      return;
    }
    const confColors = { high: '#22c55e', medium: '#f59e0b', low: '#9ca3af' };
    let html = d.summary
      ? '<div class="card" style="background:rgba(59,130,246,0.06);border-left:3px solid var(--m-primary)"><div style="font-weight:700;color:var(--m-primary)">' + escHtml(d.summary) + '</div></div>'
      : '';
    for (const r of d.reflections) {
      let icon = '📰';
      if (r.section.includes('轮动')) icon = '🔄';
      else if (r.section.includes('标的')) icon = '🎯';
      else if (r.section.includes('因子')) icon = '🔬';
      const conf = r.confidence || 'low';
      html += '<div class="card">'
        + '<div class="section-title">' + icon + ' ' + escHtml(r.section)
        + ' <span style="font-size:10px;color:' + (confColors[conf]||'#9ca3af') + '">' + conf + '</span></div>'
        + '<div style="font-size:13px;line-height:1.7;color:var(--m-text-2);white-space:pre-wrap">' + escHtml(r.content) + '</div>'
        + '</div>';
    }
    html += '<div style="font-size:10px;color:var(--m-text-3);text-align:center;padding:8px">'
      + escHtml(d.generated_at || '') + ' | ' + escHtml(d.model || '') + ' | ' + escHtml(d.period || '')
      + '</div>';
    panel.innerHTML = html;
  } catch (e) {
    panel.innerHTML = '<div class="card"><p>加载失败: ' + escHtml(String(e)) + '</p></div>';
  }
}

</script>
